{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "controller-pack-manager",
    "version": "0.1.0",
    "identifier": "com.vatita.controller-pack-manager",
    "build": {
        "beforeDevCommand": "npm run dev",
        "devUrl": "http://localhost:1420",
        "beforeBuildCommand": "npm run build",
        "frontendDist": "../dist"
    },
    "app": {
        "windows": [
            {
                "title": "VATITA Controller Pack Manager",
                "width": 1400,
                "height": 900,
                "maximized": true
            }
        ],
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "icon": [
            "icons/icon.ico"
        ]
    }
}